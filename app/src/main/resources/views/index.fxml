<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oz.ui.HomeController">
	<padding>
		<Insets top="40" right="40" bottom="40" left="40" />
	</padding>

	<Label text="Sistema de Gestão Condominial" style="-fx-font-size: 24px; -fx-font-weight: bold;" />

	<Separator />

	<VBox spacing="15" alignment="TOP_LEFT">
		<Label text="Menu Principal" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
		
		<Button fx:id="btnAreaComum" text="Áreas Comuns" onAction="#navigateToAreaComum" prefWidth="200" />
	</VBox>

</VBox>
