<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oz.ui.ReservaController">
	<padding>
		<Insets top="20" right="20" bottom="20" left="20" />
	</padding>

	<Label text="Nova Reserva" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

	<GridPane hgap="10" vgap="10">
		<Label text="Área Comum:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
		<ComboBox fx:id="areaComboBox" promptText="Selecione a área" GridPane.columnIndex="1"
			GridPane.rowIndex="0" />

		<Label text="Nome do Morador:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
		<TextField fx:id="nameField" promptText="Ex: João Silva" GridPane.columnIndex="1"
			GridPane.rowIndex="1" />

		<Label text="Apartamento:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
		<TextField fx:id="apartmentField" promptText="Ex: 101-B" GridPane.columnIndex="1"
			GridPane.rowIndex="2" />

		<Label text="Data:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
		<DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="3" />
	</GridPane>

	<Separator />

	<HBox spacing="10" alignment="CENTER_RIGHT">
		<Button text="Cancelar" onAction="#handleCancel" />
		<Button text="Confirmar Reserva" onAction="#handleSave" style="-fx-base: #2ecc71;" />
	</HBox>
</VBox>
