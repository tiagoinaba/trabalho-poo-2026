<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oz.ui.AreaController">
	<padding>
		<Insets top="20" right="20" bottom="20" left="20" />
	</padding>

	<Label text="Nova Área Comum" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

	<GridPane hgap="10" vgap="10">
		<Label text="Nome:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
		<TextField fx:id="nameField" promptText="Ex: Churrasqueira" GridPane.columnIndex="1"
			GridPane.rowIndex="0" />
	</GridPane>

	<Separator />

	<HBox spacing="10" alignment="CENTER_RIGHT">
		<Button text="Cancelar" onAction="#handleCancel" />
		<Button text="Salvar Área" onAction="#handleSave" style="-fx-base: #2ecc71;" />
	</HBox>
</VBox>
